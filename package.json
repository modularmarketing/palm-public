{
  "name": "palm-public",
  "version": "0.1.0",
  "description": "PALM - Iterable metrics and dashboard toolkit with MCP server and self-contained HTML output",
  "license": "Apache-2.0",
  "type": "commonjs",
  "main": "src/mcp-server.ts",
  "bin": {
    "palm-metrics": "./bin/palm-metrics.js"
  },
  "scripts": {
    "build": "bash scripts/build-css.sh && bun run scripts/build-binaries.sh",
    "build:css": "bash scripts/build-css.sh",
    "dev": "bun run src/mcp-server.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@types/node": "^22.0.0",
    "bun-types": "^1.3.11",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.5.0"
  }
}
